{
  "name": "deadloop",
  "version": "0.1.0",
  "description": "deadloop runs guarded GitHub issue-to-PR automation loops for coding agents. The v0 Pi package uses Herdr.",
  "keywords": ["pi-package", "pi-extension", "agent", "github", "herdr", "deadloop"],
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "test": "vitest run",
    "lint": "biome check package.json biome.json test/ci-workflow.test.ts test/package-manifest.test.ts tsconfig.json --files-ignore-unknown=true && biome lint src extensions/pi-looper/index.ts extensions/pi-looper/automations/*.ts test/*.ts --files-ignore-unknown=true",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "docs/*.md",
    "extensions/pi-looper/index.ts",
    "extensions/pi-looper/README.md",
    "extensions/pi-looper/projects.example.json",
    "extensions/pi-looper/automations/*.md",
    "extensions/pi-looper/automations/*.sh",
    "extensions/pi-looper/automations/*.ts",
    "skills/**/*.md",
    "src/**/*.ts",
    "src/**/*.cjs"
  ],
  "pi": {
    "extensions": ["./extensions/pi-looper/index.ts"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
