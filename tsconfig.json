{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.cjs",
    "extensions/pi-looper/index.ts",
    "extensions/pi-looper/automations/launch-agent.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules", ".pi-subagents"]
}
