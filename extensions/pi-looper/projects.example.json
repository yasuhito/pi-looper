{
  "projects": [
    {
      "id": "example-project",
      "enabled": true,
      "repoPath": "/absolute/path/to/your/repo",
      "githubRepo": "owner/repo",
      "baseBranch": "origin/main",
      "worktreeRoot": "/absolute/path/to/herdr/worktrees/example-project/",
      "checkCommand": "git diff --check",
      "autoMerge": false,
      "workerInstructions": "AGENTS.md and relevant project docs must be read before making changes.",
      "workerModel": "anthropic/claude-opus-4-8",
      "reviewerModel": "",
      "labels": {
        "ready": "ready-for-agent",
        "implement": "agent:implement",
        "inProgress": "agent:in-progress",
        "blocked": "agent:blocked",
        "review": "agent:review",
        "reviewing": "agent:reviewing",
        "human": "ready-for-human",
        "needsInfo": "needs-info",
        "wontfix": "wontfix",
        "needsTriage": "needs-triage"
      },
      "automations": [
        {
          "id": "example-project:issue-coordinator",
          "name": "example-project issue coordinator",
          "schedule": "*/10 * * * *",
          "promptFile": "generic-issue-coordinator.prompt.md",
          "precheckFile": "generic-issue-coordinator.precheck.sh",
          "precheckTimeoutSeconds": 60
        },
        {
          "id": "example-project:pr-reviewer",
          "name": "example-project PR reviewer",
          "schedule": "*/10 * * * *",
          "promptFile": "generic-pr-reviewer.prompt.md",
          "precheckFile": "generic-pr-reviewer.precheck.sh",
          "precheckTimeoutSeconds": 60
        }
      ]
    }
  ]
}
