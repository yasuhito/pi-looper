{
  "projects": [
    {
      "id": "example-project",
      "repoPath": "/absolute/path/to/your/repo",
      "githubRepo": "owner/repo",
      "baseBranch": "origin/main",
      "worktreeRoot": "/absolute/path/to/herdr/worktrees/example-project/",
      "autoMerge": false,
      "ciFallback": {
        "enabled": false,
        "mode": "billing-only",
        "allowAutoMerge": false,
        "localCommands": ["git diff --check"]
      },
      "externalReview": {
        "enabled": false,
        "waitSeconds": 1800
      },
      "automations": [
        {
          "id": "example-project:issue-coordinator",
          "name": "example-project issue coordinator",
          "schedule": "*/10 * * * *",
          "promptFile": "issue-coordinator.prompt.md",
          "precheckFile": "issue-coordinator.precheck.sh",
          "driverFile": "issue-coordinator-driver.ts",
          "precheckTimeoutSeconds": 60
        },
        {
          "id": "example-project:pr-reviewer",
          "name": "example-project PR reviewer",
          "schedule": "*/10 * * * *",
          "promptFile": "pr-reviewer.prompt.md",
          "precheckFile": "pr-reviewer.precheck.sh",
          "driverFile": "pr-reviewer-driver.ts",
          "precheckTimeoutSeconds": 60
        }
      ]
    }
  ]
}
